# Question 1 : Use Github Copilot to create a table SalesData whose columns are CustomerID, Name, Age, City,
# PurchaseAmount, PurchaseDate and then ask to insert 10,000 rows of random data.

# Answer
# Promt
# Write MySQL SQL code to:
#1. Create a table named SalesData with CustomerID, Name, Age, City, PurchaseAmount, and PurchaseDate.
#2. Insert 10,000 random records.
#3. Use realistic customer names, random ages (18–60), cities from major Indian cities, purchase amounts between 100 and 5000, and purchase dates from the last year.
#4. Ensure the script is fully compatible with MySQL Workbench and executes without errors.

CREATE DATABASE SalesDB;
USE SalesDB;

CREATE TABLE SalesData (
    CustomerID INT PRIMARY KEY,
    Name VARCHAR(100),
    Age INT,
    City VARCHAR(50),
    PurchaseAmount DECIMAL(10,2),
    PurchaseDate DATE
);

DELIMITER $$

CREATE PROCEDURE InsertRandomSalesData()
BEGIN
    DECLARE i INT DEFAULT 1;
    DECLARE randomCity VARCHAR(50);

    WHILE i <= 10000 DO

        SET randomCity = ELT(
            FLOOR(1 + RAND() * 8),
            'Delhi',
            'Mumbai',
            'Kolkata',
            'Chennai',
            'Bangalore',
            'Hyderabad',
            'Pune',
            'Jaipur'
        );

        INSERT INTO SalesData
        (
            CustomerID,
            Name,
            Age,
            City,
            PurchaseAmount,
            PurchaseDate
        )
        VALUES
        (
            i,
            CONCAT('Customer_', i),
            FLOOR(18 + RAND() * 43),
            randomCity,
            ROUND(100 + RAND() * 4900, 2),
            DATE_SUB(CURDATE(), INTERVAL FLOOR(RAND() * 365) DAY)
        );

        SET i = i + 1;

    END WHILE;
END$$

DELIMITER ;

CALL InsertRandomSalesData();

SELECT COUNT(*) AS TotalRows
FROM SalesData;

SELECT *
FROM SalesData
LIMIT 10;


# Question 2 : Use Copilot to: Find total sales per city, Top 5 cities by revenue

# Answer
# Prompt
# Using the SalesData table, write MySQL queries to:

#1. Find the total sales for each city by summing the PurchaseAmount.
#2. Display the results in descending order of total sales.
#3. Find the top 5 cities with the highest revenue based on the total PurchaseAmount.
#4. Use appropriate SQL functions such as SUM(), GROUP BY, ORDER BY, and LIMIT.

SELECT
    City,
    SUM(PurchaseAmount) AS TotalSales
FROM SalesData
GROUP BY City
ORDER BY TotalSales DESC;

SELECT
    City,
    SUM(PurchaseAmount) AS TotalRevenue
FROM SalesData
GROUP BY City
ORDER BY TotalRevenue DESC
LIMIT 5;


# Question 3  : Ask Copilot: Find customers with purchases above average

# Answer
# Prompt
# Using the SalesData table, write a MySQL query to find all customers whose PurchaseAmount 
#is greater than the average PurchaseAmount of all customers. Display CustomerID, Name, City,
#PurchaseAmount, and PurchaseDate. Sort the results in descending order of PurchaseAmount.

SELECT
    CustomerID,
    Name,
    City,
    PurchaseAmount,
    PurchaseDate
FROM SalesData
WHERE PurchaseAmount > (
    SELECT AVG(PurchaseAmount)
    FROM SalesData
)
ORDER BY PurchaseAmount DESC;
